{
  "extends": "@ant-design-vue/typescript-config/tsconfig.vue.json",
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "references": [{ "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "paths": {
      "#/*": ["./src/*"],
      "~/*": ["./assets/*"],
      "@/*": ["../../packages/ui/src/*"],
      "@ant-design-vue/ui": ["../../packages/ui/src/index.ts"]
    }
  }
}
