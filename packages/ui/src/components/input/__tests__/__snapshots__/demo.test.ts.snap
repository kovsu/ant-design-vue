  <!-- With prefix/suffix but no addon --><span class="ant-input-affix-wrapper"><!--v-if--><input class="ant-input" type="text" placeholder="Count without max" value=""><span class="ant-input-suffix"><!--v-if--><span class="ant-input-show-count-suffix">0</span></span></span><span class="ant-input-textarea ant-input-textarea-show-count" data-count="0 / 200"><textarea class="ant-input" placeholder="TextArea with count" rows="4" maxlength="200" value=""></textarea><span class="ant-input-textarea-suffix"><span class="ant-input-show-count-suffix">0 / 200</span></span></span>
</div>"
`;

