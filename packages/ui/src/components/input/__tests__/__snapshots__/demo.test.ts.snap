exports[`Input demos > demo: Addon 1`] = `
"<div style="display: flex; flex-direction: column; gap: 12px; max-width: 400px;">
  <!-- With addon wrapper --><span class="ant-input-group-wrapper"><span class="ant-input-wrapper ant-input-group"><span class="ant-input-group-addon">https://</span><!-- affix wrapper inside addon -->
  <!-- plain input inside addon --><input class="" type="text" placeholder="mysite" value=""><span class="ant-input-group-addon">.com</span></span></span><!-- With addon wrapper -->
  <!-- With prefix/suffix but no addon --><span class="ant-input-affix-wrapper"><span class="ant-input-prefix">$</span><input class="ant-input" type="text" placeholder="Enter amount" value=""><span class="ant-input-suffix"><!--v-if--><!--v-if-->USD</span></span><!-- With addon wrapper --><span class="ant-input-group-wrapper"><span class="ant-input-wrapper ant-input-group"><span class="ant-input-group-addon">Site</span><!-- affix wrapper inside addon --><span class="ant-input-affix-wrapper"><span class="ant-input-prefix">@</span><input class="ant-input" type="text" placeholder="With prefix and addon" value=""><span class="ant-input-suffix"><!--v-if--><!--v-if--></span></span>
  <!--v-if--></span></span>
</div>"
`;

