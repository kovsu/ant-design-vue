exports[`Upload demos > demo: Drag 1`] = `
"<div class="ant-upload-wrapper ant-upload-wrapper-text">
  <!-- Picture card: list before trigger -->
  <!-- Text / Picture: trigger before list -->
  <div class="ant-upload ant-upload-drag ant-upload-text" role="button" tabindex="0"><input type="file" class="ant-upload-input" multiple="">
    <p class="ant-upload-drag-icon"><span style="font-size: 48px; color: rgb(22, 119, 255);">📥</span></p>
    <p class="ant-upload-text">Click or drag file to this area to upload</p>
    <p class="ant-upload-hint">Support for a single or bulk upload.</p>
  </div>
  <!--v-if-->
</div>"
`;

