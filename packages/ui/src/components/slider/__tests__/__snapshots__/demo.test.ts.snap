exports[`Slider demos > demo: Vertical 1`] = `
"<div style="display: flex; gap: 48px; height: 300px;">
  <div class="ant-slider ant-slider-vertical">
    <div class="ant-slider-rail"></div>
    <div class="ant-slider-track" style="bottom: 0%; height: 30%;"></div><!-- Steps/dots -->
    <!--v-if-->
    <!-- Marks -->
    <!--v-if-->
    <!-- Handle(s) -->
    <div class="ant-slider-handle" style="bottom: 30%;" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="30" tabindex="0"></div>
  </div>
  <div class="ant-slider ant-slider-vertical">
    <div class="ant-slider-rail"></div>
    <div class="ant-slider-track" style="bottom: 20%; height: 30%;"></div><!-- Steps/dots -->
    <!--v-if-->
    <!-- Marks -->
    <!--v-if-->
    <!-- Handle(s) -->
    <div class="ant-slider-handle" style="bottom: 20%;" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="20" tabindex="0"></div>
    <div class="ant-slider-handle" style="bottom: 50%;" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0"></div>
  </div>
  <div class="ant-slider ant-slider-vertical ant-slider-with-marks">
    <div class="ant-slider-rail"></div>
    <div class="ant-slider-track" style="bottom: 0%; height: 37%;"></div><!-- Steps/dots -->
    <div class="ant-slider-step"><span class="ant-slider-dot ant-slider-dot-active" style="bottom: 0%;"></span><span class="ant-slider-dot ant-slider-dot-active" style="bottom: 26%;"></span><span class="ant-slider-dot ant-slider-dot-active" style="bottom: 37%;"></span><span class="ant-slider-dot" style="bottom: 100%;"></span></div><!-- Marks -->
    <div class="ant-slider-mark"><span class="ant-slider-mark-text ant-slider-mark-text-active" style="bottom: 0%;">0°C</span><span class="ant-slider-mark-text ant-slider-mark-text-active" style="bottom: 26%;">26°C</span><span class="ant-slider-mark-text ant-slider-mark-text-active" style="bottom: 37%;">37°C</span><span class="ant-slider-mark-text" style="bottom: 100%;">100°C</span></div><!-- Handle(s) -->
    <div class="ant-slider-handle" style="bottom: 37%;" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="37" tabindex="0"></div>
  </div>
</div>"
`;
