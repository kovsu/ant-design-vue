exports[`Avatar demos > demo: Basic 1`] = `"<div style="display: flex; gap: 16px; align-items: center;"><span class="ant-avatar ant-avatar-circle ant-avatar-image" role="img" aria-label="User avatar"><img src="https://api.dicebear.com/7.x/miniavs/svg?seed=1" alt="User avatar" draggable="false"></span><span class="ant-avatar ant-avatar-circle" role="img"><span class="ant-avatar-string">U</span></span><span class="ant-avatar ant-avatar-circle ant-avatar-icon" role="img"><span style="font-size: 18px;">👤</span></span><span class="ant-avatar ant-avatar-square" role="img"><span class="ant-avatar-string">S</span></span><span class="ant-avatar ant-avatar-square ant-avatar-image" role="img" aria-label="Square avatar"><img src="https://api.dicebear.com/7.x/miniavs/svg?seed=2" alt="Square avatar" draggable="false"></span></div>"`;

