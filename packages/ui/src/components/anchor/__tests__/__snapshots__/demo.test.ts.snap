exports[`Anchor demos > demo: Basic 1`] = `
"<div class="ant-anchor ant-anchor-vertical">
  <div class="ant-anchor-wrapper">
    <!-- Ink indicator (vertical only) --><span class="ant-anchor-ink" style="display: none;"></span><!-- Items-based rendering -->
