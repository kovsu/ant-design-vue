// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Tabs demos > demo: Basic 1`] = `
"<div class="ant-tabs ant-tabs-top ant-tabs-line ant-tabs-md">
  <!-- Tab bar -->
  <div class="ant-tabs-nav" role="tablist" aria-orientation="horizontal">
    <!-- Left extra -->
    <!--v-if-->
    <div class="ant-tabs-nav-wrap">
      <div class="ant-tabs-nav-list">
        <!-- Tab buttons -->
        <!-- Ink bar (line type only) -->
        <div class="ant-tabs-ink-bar"></div>
      </div>
    </div><!-- Add button for editable-card -->
    <!--v-if-->
    <!-- Right extra -->
    <!--v-if-->
  </div><!-- Tab content -->
  <div class="ant-tabs-content-holder">
    <div class="ant-tabs-content">
      <!-- Items-based content -->
      <!-- Slot-based content (TabPane children) -->
      <div class="ant-tabs-tabpane ant-tabs-tabpane-active" role="tabpanel" aria-hidden="false">Content of Tab Pane 1</div>
      <div class="ant-tabs-tabpane" role="tabpanel" aria-hidden="true" style="display: none;">Content of Tab Pane 2</div>
      <div class="ant-tabs-tabpane" role="tabpanel" aria-hidden="true" style="display: none;">Content of Tab Pane 3</div>
    </div>
  </div>
</div>"
`;

