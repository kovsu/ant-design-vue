exports[`Tabs demos > demo: Items 1`] = `
"<div class="ant-tabs ant-tabs-top ant-tabs-line ant-tabs-md">
  <!-- Tab bar -->
  <div class="ant-tabs-nav" role="tablist" aria-orientation="horizontal">
    <!-- Left extra -->
    <!--v-if-->
    <div class="ant-tabs-nav-wrap">
      <div class="ant-tabs-nav-list">
        <!-- Tab buttons -->
        <div class="ant-tabs-tab ant-tabs-tab-active" role="tab" aria-selected="true" tabindex="0"><span class="ant-tabs-tab-label">Tab 1</span><!-- Remove button for editable-card -->
          <!--v-if-->
        </div>
        <div class="ant-tabs-tab" role="tab" aria-selected="false" tabindex="-1"><span class="ant-tabs-tab-label">Tab 2</span><!-- Remove button for editable-card -->
          <!--v-if-->
        </div>
        <div class="ant-tabs-tab" role="tab" aria-selected="false" tabindex="-1"><span class="ant-tabs-tab-label">Tab 3</span><!-- Remove button for editable-card -->
          <!--v-if-->
        </div><!-- Ink bar (line type only) -->
        <div class="ant-tabs-ink-bar"></div>
      </div>
    </div><!-- Add button for editable-card -->
    <!--v-if-->
    <!-- Right extra -->
    <!--v-if-->
  </div><!-- Tab content -->
  <div class="ant-tabs-content-holder">
    <div class="ant-tabs-content">
      <!-- Items-based content -->
      <div class="ant-tabs-tabpane ant-tabs-tabpane-active" role="tabpanel" aria-hidden="false">Content of Tab 1</div>
      <div class="ant-tabs-tabpane" role="tabpanel" aria-hidden="true" style="display: none;">Content of Tab 2</div>
      <div class="ant-tabs-tabpane" role="tabpanel" aria-hidden="true" style="display: none;">Content of Tab 3</div>
    </div>
  </div>
</div>"
`;

