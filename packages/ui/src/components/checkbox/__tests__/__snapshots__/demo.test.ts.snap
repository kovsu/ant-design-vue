exports[`Checkbox demos > demo: CheckAll 1`] = `
"<div style="display: flex; flex-direction: column; gap: 12px;"><label class="ant-checkbox-wrapper"><span class="ant-checkbox ant-checkbox-indeterminate"><input type="checkbox" class="ant-checkbox-input" role="checkbox" aria-checked="mixed"><span class="ant-checkbox-inner"></span></span><span class="ant-checkbox-label"> Check all </span></label>
  <hr style="margin: 0px; border-top: 1px solid rgb(217, 217, 217);">
  <div class="ant-checkbox-group" role="group"><label class="ant-checkbox-wrapper ant-checkbox-wrapper-checked"><span class="ant-checkbox ant-checkbox-checked"><input type="checkbox" class="ant-checkbox-input" checked="" role="checkbox" aria-checked="true"><span class="ant-checkbox-inner"></span></span><span class="ant-checkbox-label">Apple</span></label><label class="ant-checkbox-wrapper"><span class="ant-checkbox"><input type="checkbox" class="ant-checkbox-input" role="checkbox" aria-checked="false"><span class="ant-checkbox-inner"></span></span><span class="ant-checkbox-label">Pear</span></label><label class="ant-checkbox-wrapper ant-checkbox-wrapper-checked"><span class="ant-checkbox ant-checkbox-checked"><input type="checkbox" class="ant-checkbox-input" checked="" role="checkbox" aria-checked="true"><span class="ant-checkbox-inner"></span></span><span class="ant-checkbox-label">Orange</span></label><label class="ant-checkbox-wrapper"><span class="ant-checkbox"><input type="checkbox" class="ant-checkbox-input" role="checkbox" aria-checked="false"><span class="ant-checkbox-inner"></span></span><span class="ant-checkbox-label">Mango</span></label></div>
</div>"
`;

